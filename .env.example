# APP SETTINGS
APP_NAME=Smart E-commerce Assistant
APP_ENV=development
LOG_LEVEL=INFO
VERSION=v1
MAX_AGENT_STEPS=5

# API SETTINGS
API_HOST=127.0.0.1
API_PORT=8000
STREAMLIT_PORT=8501

# OPENAI SETTINGS
OPENAI_API_KEY=your_openai_api_key_here

# GEMINI SETTINGS
GEMINI_API_KEY=your_gemini_api_key_here

# LOCAL LLM SETTINGS (optional)
# Install requirements-local.txt if you want local GGUF support.
LOCAL_MODEL_PATH=./models/Phi-3-mini-4k-instruct-q4.gguf

# PROVIDER CONFIG
# Options: openai | google | local | mock
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# DATABASE SETTINGS
POSTGRES_DB=lab03
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/lab03
